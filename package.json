{
  "name": "domain-intel-mcp",
  "version": "1.0.0",
  "description": "One-call domain intelligence: tech stack, DNS, SSL, WHOIS, subdomains, social profiles — normalized into a single typed object.",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ctxprotocol/sdk": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.2",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.3.2"
  }
}
